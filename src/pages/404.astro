---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Page Not Found | RealityCheck Tools" description="This page doesn't exist. Even our calculator can't measure your disappointment.">
  <div style="text-align:center;padding:80px 20px;">
    <div style="font-size:80px;font-weight:400;color:var(--primary);font-family:var(--display);letter-spacing:-2px;margin-bottom:16px;">404</div>
    <h1>Page Not Found</h1>
    <p style="color:var(--muted);font-size:16px;max-width:500px;margin:16px auto;">(but don't worry, we can't measure your disappointment either)</p>
    <div style="margin-top:32px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="/" class="btn-primary">Go Home</a>
      <a href="/tools/doomscroll" class="btn-secondary">Try Doomscroll Calculator</a>
    </div>
    <p style="margin-top:40px;color:var(--muted);font-size:13px;">Looking for something else? Try our <a href="/" class="text-link">tool hub</a>.</p>
  </div>
</Layout>
