---
import Layout from '../layouts/Layout.astro';
import { icon } from '../lib/icons';

const maskIcon = icon('mask', 32);
const barChartIcon = icon('barChart', 32);
const smartphoneIcon = icon('smartphone', 32);
const lockIcon = icon('lock', 32);

const tools = [
  { title: "Doomscroll Tax Calculator", description: "Calculate how many years of your life you've sacrificed to the infinite scroll.", painLevel: 8, category: "time-waste", slug: "doomscroll" },
  { title: "Subscription Vampire Tracker", description: "Discover how much your 'small' monthly subscriptions drain from your wallet.", painLevel: 7, category: "finance", slug: "subscription" },
  { title: "Coffee-to-Downpayment Calculator", description: "See how your daily coffee habit stacks up against a real-life downpayment.", painLevel: 6, category: "finance", slug: "coffee" },
  { title: "Gym Membership Reality Checker", description: "Calculate exactly how much each gym visit actually costs you.", painLevel: 9, category: "health", slug: "gym" },
  { title: "Sleep Debt Calculator", description: "Find out how many hours of sleep you owe your body (interest compounding daily).", painLevel: 5, category: "health", slug: "sleep" },
  { title: "Productivity Theater Analyzer", description: "Measure how much time you spend optimizing your workflow instead of working.", painLevel: 6, category: "productivity", slug: "productivity" },
  { title: "Future Regret Simulator", description: "Calculate how disappointed Future You will be about the goals you didn't start.", painLevel: 10, category: "life", slug: "future-regret" },
  { title: "Career Drift Calculator", description: "See if you're building a career or just getting really good at opening Jira tickets.", painLevel: 8, category: "career", slug: "career-drift" },
  { title: "AI Replacement Probability Generator", description: "Find out how likely your job is to be automated (spoiler: it's higher than you think).", painLevel: 9, category: "career", slug: "ai-probability" },
  { title: "Group Project Load Balancer", description: "Quantify exactly how much you carried your team (and how much they didn't).", painLevel: 7, category: "productivity", slug: "group-project" },
  { title: "Relationship ROI Calculator", description: "Calculate the return on your emotional investment (results may sting).", painLevel: 8, category: "life", slug: "relationship-roi" },
  { title: "Existential Alarm Clock", description: "See exactly how many mornings you have left. No pressure.", painLevel: 10, category: "life", slug: "existential-alarm" }
];
---

<Layout title="RealityCheck Tools — Apna Sach Sun. Sudhar Ja." description="Bina matlab ke calculators jo dikhate hain teri aadat ki asli keemat. Doomscroll tax, subscription vampires, coffee downpayment, aur aur bhi reality checks.">
  <section class="hero-band">
    <h1>Apna Sach Sun. <span class="hero-accent">Sudhar Ja.</span></h1>
    <p class="hero-subtitle">Bina matlab ke calculators jo dikhate hain teri aadat ki asli keemat. Na sugarcoating, na bakwas. Bas sach.</p>
    <div class="hero-actions">
      <a href="#tools" class="btn-primary">Dikhade Apna Haal</a>
      <a href="/tools/doomscroll" class="btn-secondary">Pehle Doomscroll Dekh</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">12</span>
        <span class="stat-label">Badtameez Tools</span>
      </div>
      <div class="stat">
        <span class="stat-value">5</span>
        <span class="stat-label">Bolne Ke Tarike</span>
      </div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Bina Filter</span>
      </div>
    </div>
  </section>

  <section id="tools" class="section-padding" style="padding-top:0;">
    <div class="container">
      <div class="section-header">
        <h2>Apna Sach Chuno</h2>
        <p class="section-subtitle">Tool chuno, sach suno.</p>
      </div>
      <div class="tool-grid">
        {tools.map(tool => (
          <a href={`/tools/${tool.slug}`} class="tool-card">
            <div class="pain" set:html={Array(tool.painLevel).fill(icon('skull', 14)).join(' ')}></div>
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
            <div class="card-footer">
              <span class="category-tag">{tool.category}</span>
              <span style="color:var(--muted);font-size:13px;font-weight:500;">Calculate &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="band-dark">
    <div class="container">
      <div class="section-header">
        <h2>Kaise Kaam Karta Hai</h2>
        <p class="section-subtitle">Simple math. Zero bakwas.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card-dark">
          <div class="feature-emoji" set:html={maskIcon}></div>
          <h5>5 Tarike Ke Bakwas</h5>
          <p>Friendly se Indian Parent tak — jaisa roast chahiye, waisa suno.</p>
        </div>
        <div class="feature-card-dark">
          <div class="feature-emoji" set:html={barChartIcon}></div>
          <h5>Sachchi Ganit</h5>
          <p>Har calculator asli numbers use karta hai. Results dard de sakte hain.</p>
        </div>
        <div class="feature-card-dark">
          <div class="feature-emoji" set:html={smartphoneIcon}></div>
          <h5>Dard Baant Lo</h5>
          <p>Share cards banao aur apne doston ko X/Twitter pe roast karo.</p>
        </div>
        <div class="feature-card-dark">
          <div class="feature-emoji" set:html={lockIcon}></div>
          <h5>Chup Chup</h5>
          <p>Sare calculations tere browser mein hote hain. Hum teri shame store nahi karte.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
