---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Humse Baat Karo — RealityCheck Tools" description="Baat karo RealityCheck.tools team se.">
  <div class="section-padding" style="max-width:600px;margin:0 auto;text-align:center;padding-top:48px;">
    <h1 style="font-size:48px;">Humse Baat Karo</h1>
    <p style="color:var(--muted);margin-bottom:32px;">Koi tool idea hai? Bug report karna hai? Ya bas vent karna hai?</p>
    <div style="background:var(--surface-card);border-radius:var(--radius-lg);padding:var(--space-xl);text-align:left;">
      <div class="tool-input-group"><label for="name">Name</label><input type="text" id="name" placeholder="Your name" /></div>
      <div class="tool-input-group"><label for="email">Email</label><input type="text" id="email" placeholder="your@email.com" /></div>
      <div class="tool-input-group"><label for="message">Message</label><textarea id="message" rows="5"></textarea></div>
      <button class="btn-primary" id="contact-btn" style="width:100%;justify-content:center;">Bhej De</button>
      <p id="contact-feedback" style="margin-top:12px;color:var(--success);font-size:14px;display:none;">Bhej diya! Hum reply karenge (kabhi toh).</p>
    </div>
  </div>
</Layout>
<script>
  document.getElementById('contact-btn')?.addEventListener('click', function() {
    document.getElementById('contact-feedback').style.display = 'block';
  });
</script>
