---
import Layout from '../../layouts/Layout.astro';
import ToneSelector from '../../components/ToneSelector.astro';
const seoKeywords = "group project calculator, teamwork imbalance, project load balancer, contribution tracker";
---
<Layout title="Group Project Load Balancer — RealityCheck Tools" description="Quantify exactly how much you carried your team (and how much they didn't)." seoKeywords={seoKeywords}>
  <div class="tool-hero">
    <h1>Group Project Load Balancer</h1>
    <p class="subtitle">Pata kar tu kitna apni team ko utha ke le gaya (aur unhone kitna nahi uthaya).</p>
  </div>
  <div class="tool-form">
    <ToneSelector currentTone="whatsapp" />
    <div class="tool-input-group">
      <label for="groupMembers">Number of group members (including you)</label>
      <input type="number" id="groupMembers" min="2" max="20" value="4" />
    </div>
    <div class="tool-input-group">
      <label for="yourHours">Hours you actually worked</label>
      <input type="number" id="yourHours" min="0" max="200" step="0.5" value="40" />
    </div>
    <div class="tool-input-group">
      <label for="theirHours">Average hours each other member worked</label>
      <input type="number" id="theirHours" min="0" max="200" step="0.5" value="7" />
    </div>
    <button class="btn-primary" id="calculate-btn" style="width:100%;justify-content:center;">Boja Dekh</button>
    <div id="results" style="display:none;">
      <div class="result-card" id="result-card">
        <div class="result-text" id="result-text"></div>
        <div id="load-results" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--hairline-soft);"></div>
      </div>
    </div>
  </div>
</Layout>
<script>
  document.getElementById('calculate-btn').addEventListener('click', function() {
    var total = parseInt(document.getElementById('groupMembers').value) || 4;
    var yourH = parseFloat(document.getElementById('yourHours').value) || 40;
    var theirH = parseFloat(document.getElementById('theirHours').value) || 7;
    var others = total - 1;
    var totalOther = theirH * others;
    var projTotal = yourH + totalOther;
    var yourPct = (yourH / projTotal) * 100;
    var fair = 100 / total;
    var t = document.querySelector('.tone-btn.active')?.dataset?.tone || 'whatsapp';
    var msgs = {
      friendly: 'You did ' + yourPct.toFixed(0) + '% of the work (' + yourH + 'h). Fair share was ' + fair.toFixed(0) + '%. You\'re a team player! ' + renderIcon('star', 14),
      brutal: 'You completed <strong>' + yourPct.toFixed(0) + '%</strong> of the project while ' + others + ' member' + (others > 1 ? 's' : '') + ' contributed <strong>emotional support</strong>. Fair share: ' + fair.toFixed(0) + '%. You did ' + (yourPct - fair).toFixed(0) + '% more than your share.',
      'passive-aggressive': 'Oh, you only did ' + yourPct.toFixed(0) + '% of the work? I\'m sure the other ' + others + ' members\' ' + theirH + 'h each was very helpful. ' + renderIcon('smile', 14),
      'corporate-hr': 'Resource allocation analysis: You contributed ' + yourPct.toFixed(0) + '% of total project hours. Team equity gap: ' + (yourPct - fair).toFixed(0) + '%. Recommend team restructuring.',
      'indian-parent': 'Beta, you did ' + yourPct.toFixed(0) + '% of the project? That\'s ' + (yourPct - fair).toFixed(0) + '% more than your share. Sharma ji\'s son\'s group all did equal work.',
      whatsapp: 'Group project mein tera ' + yourPct.toFixed(0) + '% contribution? 😂 Baaki ' + others + ' log toh "moral support" de rahe the. Fair share tha ' + fair.toFixed(0) + '% lekin tu ' + (yourPct - fair).toFixed(0) + '% zyada le gaya. Agli baar group chat mein hi project kar lena. ' + renderIcon('skull', 14)
    };
    document.getElementById('result-text').innerHTML = msgs[t] || msgs.brutal;
    document.getElementById('load-results').innerHTML =
      '<div style="margin-top:16px;"><div style="display:flex;justify-content:space-between;margin-bottom:4px;">' +
      '<span style="color:var(--muted);font-size:13px;">Your contribution</span>' +
      '<span style="color:var(--primary);font-weight:600;font-size:13px;">' + yourPct.toFixed(0) + '%</span></div>' +
      '<div style="height:8px;background:var(--hairline);border-radius:4px;overflow:hidden;">' +
      '<div style="height:100%;width:' + yourPct + '%;background:var(--primary);border-radius:4px;"></div></div>' +
      '<div style="display:flex;justify-content:space-between;margin:8px 0 4px;">' +
      '<span style="color:var(--muted);font-size:13px;">Your fair share</span>' +
      '<span style="color:var(--muted);font-weight:600;font-size:13px;">' + fair.toFixed(0) + '%</span></div>' +
      '<div style="height:8px;background:var(--hairline);border-radius:4px;overflow:hidden;">' +
      '<div style="height:100%;width:' + fair + '%;background:var(--muted);border-radius:4px;opacity:0.5;"></div></div></div>' +
      '<p style="margin-top:12px;font-size:13px;color:var(--muted);">Your hours: ' + yourH + ' | Others\' avg: ' + theirH + 'h | Total: ' + projTotal + 'h</p>';
    document.getElementById('results').style.display = 'block';
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
