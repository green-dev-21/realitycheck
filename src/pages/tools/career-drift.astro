---
import Layout from '../../layouts/Layout.astro';
import ToneSelector from '../../components/ToneSelector.astro';
const seoKeywords = "career stagnation calculator, skill growth tracker, career drift, job growth calculator";
---
<Layout title="Career Drift Calculator — RealityCheck Tools" description="See if you're building a career or just getting really good at opening Jira tickets." seoKeywords={seoKeywords}>
  <div class="tool-hero">
    <h1>Career Drift Calculator</h1>
    <p class="subtitle">Pata kar tu career bana raha hai ya bas Jira tickets kholne ka expert ban raha hai.</p>
  </div>
  <div class="tool-form">
    <ToneSelector currentTone="whatsapp" />
    <div class="tool-input-group">
      <label for="yearsInJob">Years in current job/field</label>
      <input type="number" id="yearsInJob" min="0" max="50" step="0.5" value="3" />
    </div>
    <div class="tool-input-group">
      <label for="skillsPerYear">New skills learned per year</label>
      <input type="number" id="skillsPerYear" min="0" max="50" value="1" />
    </div>
    <div class="tool-input-group">
      <label for="hoursProcrastinating">Hours per week saying "I'll learn later"</label>
      <input type="number" id="hoursProcrastinating" min="0" max="40" step="0.5" value="5" />
    </div>
    <button class="btn-primary" id="calculate-btn" style="width:100%;justify-content:center;">Drift Check Kar</button>
    <div id="results" style="display:none;">
      <div class="result-card" id="result-card">
        <div class="result-text" id="result-text"></div>
        <div id="drift-results" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--hairline-soft);"></div>
      </div>
    </div>
  </div>
</Layout>
<script>
  document.getElementById('calculate-btn').addEventListener('click', function() {
    var years = parseFloat(document.getElementById('yearsInJob').value) || 3;
    var skillsPY = parseInt(document.getElementById('skillsPerYear').value) || 1;
    var hProc = parseFloat(document.getElementById('hoursProcrastinating').value) || 5;
    var totalSkills = skillsPY * years;
    var totalWasted = hProc * 52 * years;
    var growth = Math.min(100, (skillsPY / 12) * 100);
    var outcomes = [
      'At this pace, you\'ll become highly experienced in <strong>opening Jira tickets</strong>.',
      'You\'ve accumulated ' + totalWasted.toFixed(0) + ' hours of "I\'ll learn later." Later is now. It\'s not looking good.',
      'With ' + totalSkills + ' new skills in ' + years + ' years, you\'re growing at <strong>' + growth.toFixed(0) + '%</strong> of the recommended rate.'
    ];
    var t = document.querySelector('.tone-btn.active')?.dataset?.tone || 'whatsapp';
    var outcome = outcomes[Math.floor(Math.random() * outcomes.length)];
    var msgs = {
      friendly: 'In ' + years + ' years, you\'ve learned ' + totalSkills + ' new skills. That\'s ' + skillsPY + '/year. Room to grow! ' + renderIcon('star', 14),
      brutal: 'In <strong>' + years + ' years</strong> at your job, you\'ve learned <strong>' + totalSkills + ' skills</strong> while spending ' + totalWasted.toFixed(0) + ' hours saying you\'ll learn later. ' + outcome,
      'passive-aggressive': totalSkills + ' skills in ' + years + ' years. At this rate, you\'ll be an expert by the time retirement hits. ' + renderIcon('smile', 14),
      'corporate-hr': 'Career trajectory analysis: ' + years + ' years tenure, ' + skillsPY + ' skills/year acquisition rate. ' + totalWasted.toFixed(0) + ' hours in professional development procrastination.',
      'indian-parent': 'Beta, ' + years + ' years and only ' + totalSkills + ' skills? Sharma ji\'s son learned ' + Math.max(skillsPY * 2, 3) + ' skills last year alone.',
      whatsapp: 'Bhai, ' + years + ' saal mein sirf ' + totalSkills + ' skills?! 🤡 ' + totalWasted.toFixed(0) + ' hours waste "sikhunga kal" bol bol ke. Career drift nahi, career cliff hai ye. Abhi uth aur kuch seekh. ' + renderIcon('book', 14) + '👊'
    };
    document.getElementById('result-text').innerHTML = msgs[t] || msgs.brutal;
    document.getElementById('drift-results').innerHTML =
      '<p style="font-size:22px;font-weight:500;font-family:var(--display);color:' + (growth < 30 ? 'var(--error)' : 'var(--accent-amber)') + ';">' + totalWasted.toFixed(0) + ' hours of "I\'ll learn later"</p>' +
      '<p style="font-size:13px;color:var(--muted);margin-top:8px;">Skills: ' + totalSkills + ' in ' + years + ' years | Growth rate: ' + growth.toFixed(0) + '%<br>Hours procrastinated: ' + totalWasted.toFixed(0) + '</p>';
    document.getElementById('results').style.display = 'block';
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
