---
import Layout from '../../layouts/Layout.astro';
import ToneSelector from '../../components/ToneSelector.astro';
const seoKeywords = "life expectancy calculator, mornings left, existential alarm, mortality reminder";
---
<Layout title="Existential Alarm Clock — RealityCheck Tools" description="See exactly how many mornings you have left. Life expectancy calculator with a brutal twist." seoKeywords={seoKeywords}>
  <div class="tool-hero">
    <h1>Existential Alarm Clock</h1>
    <p class="subtitle">See exactly how many mornings you have left. No pressure.</p>
  </div>
  <div class="tool-form">
    <ToneSelector currentTone="brutal" />
    <div class="tool-input-group">
      <label for="currentAge">Your current age</label>
      <input type="number" id="currentAge" min="1" max="100" value="25" />
    </div>
    <div class="tool-input-group">
      <label for="lifeExpectancy">Life expectancy (defaults to average)</label>
      <input type="number" id="lifeExpectancy" min="50" max="120" value="80" />
    </div>
    <div class="tool-input-group">
      <label for="morningsSnoozed">Mornings you hit snooze per week</label>
      <input type="number" id="morningsSnoozed" min="0" max="7" value="5" />
    </div>
    <button class="btn-primary" id="calculate-btn" style="width:100%;justify-content:center;">Wake Me Up</button>
    <div id="results" style="display:none;">
      <div class="result-card" id="result-card">
        <div class="result-text" id="result-text"></div>
        <div id="existential-results" style="margin-top:16px;padding-top:16px;border-top:1px solid var(--hairline-soft);"></div>
      </div>
    </div>
  </div>
</Layout>
<script>
  document.getElementById('calculate-btn').addEventListener('click', function() {
    var age = parseInt(document.getElementById('currentAge').value) || 25;
    var lifeExp = parseInt(document.getElementById('lifeExpectancy').value) || 80;
    var snoozed = parseInt(document.getElementById('morningsSnoozed').value) || 5;
    var yearsLeft = lifeExp - age;
    var mornings = yearsLeft * 365;
    var weekends = yearsLeft * 52;
    var christmases = yearsLeft;
    var snoozedTotal = snoozed * 52 * yearsLeft;
    var snoozedDays = snoozedTotal * 0.08;
    var t = document.querySelector('.tone-btn.active')?.dataset?.tone || 'brutal';
    var msgs = {
      friendly: 'You have approximately <strong>' + mornings.toLocaleString() + ' mornings</strong> left. Make them count! 🌟',
      brutal: 'You have approximately <strong>' + mornings.toLocaleString() + ' mornings</strong> left. Maybe don\'t spend <strong>' + snoozedTotal.toLocaleString() + ' (' + snoozedDays.toFixed(0) + ' days)</strong> of them hitting snooze.',
      'passive-aggressive': 'Only ' + mornings.toLocaleString() + ' mornings left. But sure, hit snooze ' + snoozed + 'x/week on ' + snoozedTotal.toLocaleString() + ' of them. 😊',
      'corporate-hr': 'Lifecycle projection: ' + mornings.toLocaleString() + ' remaining mornings. Snooze utilization: ' + snoozedTotal.toLocaleString() + ' instances. That\'s ' + snoozedDays.toFixed(0) + ' days of unoptimized wake cycles.',
      'indian-parent': 'Beta, you have ' + mornings.toLocaleString() + ' mornings left on this earth. You want to spend ' + snoozedTotal.toLocaleString() + ' of them sleeping in? Sharma ji\'s son wakes up at 5 AM.',
      whatsapp: 'Bhai/sis, tere paas bas ' + mornings.toLocaleString() + ' subah bachi hain zindagi mein. ☀️ Aur tu ' + snoozedTotal.toLocaleString() + ' baar snooze marega? ' + snoozedDays.toFixed(0) + ' din barbaad sirf "5 more minutes" mein. Life short hai, snooze mat kar. ⏰💀'
    };
    var alarmColor = age > 60 ? 'var(--error)' : age > 40 ? 'var(--accent-amber)' : 'var(--accent-amber)';
    document.getElementById('result-text').innerHTML = msgs[t] || msgs.brutal;
    document.getElementById('existential-results').innerHTML =
      '<div style="text-align:center;padding:16px 0;"><div style="font-size:48px;font-weight:400;font-family:var(--display);color:' + alarmColor + ';letter-spacing:-1px;">' + mornings.toLocaleString() + '</div>' +
      '<div style="color:var(--muted);font-size:13px;">mornings remaining</div></div>' +
      '<p style="font-size:13px;color:var(--muted);text-align:center;">' + yearsLeft + ' years left · ' + weekends.toLocaleString() + ' weekends · ' + christmases + ' Christmases<br>You\'ll snooze away ' + snoozedDays.toFixed(0) + ' full days of your remaining life</p>';
    document.getElementById('results').style.display = 'block';
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
