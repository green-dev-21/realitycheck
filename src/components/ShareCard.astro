---
import { icon } from '../lib/icons';

export interface Props {
  resultText: string;
  toolName: string;
  value?: string;
}

const { resultText, toolName, value } = Astro.props;
---

<div class="share-card-wrapper">
  <div class="share-card" id="share-card">
    <div class="share-card-content">
      <div class="share-card-toolname">{toolName}</div>
      <div class="share-card-result">{resultText}</div>
      {value && <div class="share-card-value">{value}</div>}
      <div class="share-card-watermark">RealityCheck.tools</div>
    </div>
  </div>
  <div class="share-section">
    <button class="share-btn" id="copy-share-btn">{icon('copy', 14)} Copy Image</button>
    <a class="share-btn" id="twitter-share-btn" href="#" target="_blank" rel="noopener">{icon('twitter', 14)} Share on X</a>
  </div>
</div>

<style>
  .share-card-wrapper {
    margin-top: 20px;
  }

  .share-card {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1.91 / 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-dark);
    border: 1px solid var(--surface-dark-elevated);
  }

  .share-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(204,120,92,0.12) 0%, transparent 60%),
                radial-gradient(circle at 20% 80%, rgba(93,184,166,0.08) 0%, transparent 50%);
  }

  .share-card-content {
    position: relative;
    padding: 28px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .share-card-toolname {
    font-size: 12px;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
    margin-bottom: 8px;
    font-family: var(--body-font);
  }

  .share-card-result {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--on-dark);
    font-weight: 400;
    font-family: var(--display);
    letter-spacing: -0.3px;
  }

  .share-card-value {
    font-size: 2rem;
    font-weight: 500;
    color: var(--primary);
    margin-top: 8px;
    font-family: var(--display);
  }

  .share-card-watermark {
    margin-top: auto;
    font-size: 12px;
    color: var(--on-dark-soft);
    opacity: 0.5;
    letter-spacing: 1px;
    font-weight: 500;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const shareCard = document.getElementById('share-card');
    const twitterBtn = document.getElementById('twitter-share-btn');
    const copyBtn = document.getElementById('copy-share-btn');

    const resultText = shareCard?.querySelector('.share-card-result')?.textContent || '';
    const toolName = shareCard?.querySelector('.share-card-toolname')?.textContent || '';

    const tweetText = resultText + '\n\nCalculate yours at RealityCheck.tools';
    twitterBtn?.setAttribute('href', 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(tweetText));

    copyBtn?.addEventListener('click', async function() {
      try {
        var canvas = document.createElement('canvas');
        var ctx = canvas.getContext('2d');
        var rect = shareCard.getBoundingClientRect();
        canvas.width = rect.width * 2;
        canvas.height = rect.height * 2;
        ctx.scale(2, 2);

        var bgGrad = ctx.createLinearGradient(0, 0, rect.width, rect.height);
        bgGrad.addColorStop(0, '#181715');
        bgGrad.addColorStop(0.3, '#1a1412');
        bgGrad.addColorStop(0.6, '#181715');
        bgGrad.addColorStop(1, '#1f1e1b');
        ctx.fillStyle = bgGrad;
        ctx.fillRect(0, 0, rect.width, rect.height);

        ctx.fillStyle = '#cc785c';
        ctx.font = '500 14px Inter, system-ui, sans-serif';
        ctx.fillText(toolName.toUpperCase(), 28, 45);

        ctx.fillStyle = '#faf9f5';
        ctx.font = '400 22px "EB Garamond", "Times New Roman", serif';
        var lines = wrapCanvasText(ctx, resultText, rect.width - 56);
        for (var i = 0; i < lines.length; i++) {
          ctx.fillText(lines[i], 28, 85 + i * 30);
        }

        ctx.fillStyle = 'rgba(160,157,150,0.5)';
        ctx.font = '500 12px Inter, system-ui, sans-serif';
        ctx.fillText('RealityCheck.tools', 28, rect.height - 20);

        canvas.toBlob(function(blob) {
          if (blob) {
            navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
            copyBtn.textContent = 'Copied!';
            setTimeout(function() { copyBtn.innerHTML = renderIcon('copy', 14) + ' Copy Image'; }, 2000);
          }
        });
      } catch(e) {
        copyBtn.innerHTML = renderIcon('check', 14) + ' Try screenshot';
        setTimeout(function() { copyBtn.innerHTML = renderIcon('copy', 14) + ' Copy Image'; }, 2000);
      }
    });

    function wrapCanvasText(ctx, text, maxWidth) {
      var words = text.split(' ');
      var lines = [];
      var line = '';
      for (var w = 0; w < words.length; w++) {
        var test = line + words[w] + ' ';
        if (ctx.measureText(test).width > maxWidth && line) {
          lines.push(line.trim());
          line = words[w] + ' ';
        } else {
          line = test;
        }
      }
      if (line.trim()) lines.push(line.trim());
      return lines.length ? lines : [text];
    }
  });
</script>
