---
import { icon } from '../lib/icons';

const { currentTone = 'brutal' } = Astro.props;

const tones = [
  { id: 'friendly', label: 'Friendly', iconName: 'star' },
  { id: 'brutal', label: 'Brutal', iconName: 'flame' },
  { id: 'passive-aggressive', label: 'Passive-Aggressive', iconName: 'smile' },
  { id: 'corporate-hr', label: 'Corporate HR', iconName: 'barChart' },
  { id: 'indian-parent', label: 'Indian Parent', iconName: 'indianRupee' },
  { id: 'whatsapp', label: 'WhatsApp', iconName: 'messageCircle' },
];
---

<div class="tone-selector">
  {tones.map((tone) => (
    <button
      class="tone-btn"
      class:list={{ active: currentTone === tone.id }}
      data-tone={tone.id}
    >
      <span set:html={icon(tone.iconName, 14)}></span> {tone.label}
    </button>
  ))}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.tone-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        localStorage.setItem('realitycheck-tone', btn.dataset.tone);
      });
    });

    const savedTone = localStorage.getItem('realitycheck-tone');
    if (savedTone) {
      const btn = document.querySelector(`.tone-btn[data-tone="${savedTone}"]`);
      if (btn) {
        document.querySelectorAll('.tone-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      }
    }
  });
</script>
