---
export interface Props {
  title: string;
  description: string;
  seoKeywords?: string;
}
const { title, description, seoKeywords } = Astro.props;
const keywords = seoKeywords || "reality check, life calculator, sarcastic tools, productivity calculator, time waste calculator, financial reality check, self improvement";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="RealityCheck Tools" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RealityCheck Tools" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">R<span class="logo-accent">ealityCheck</span><span class="logo-tld">.tools</span></a>
        <div class="header-right">
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">🌙</button>
          <button class="hamburger" id="hamburger" aria-label="Toggle menu">
            <span></span><span></span><span></span>
          </button>
          <nav class="top-nav" id="top-nav">
            <a href="/">Tools</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4>Tools</h4>
            <a href="/tools/doomscroll">Doomscroll Tax</a>
            <a href="/tools/subscription">Subscription Tracker</a>
            <a href="/tools/coffee">Coffee Calculator</a>
            <a href="/tools/gym">Gym Reality Check</a>
            <a href="/tools/sleep">Sleep Debt</a>
            <a href="/tools/productivity">Productivity Theater</a>
            <a href="/tools/future-regret">Future Regret</a>
            <a href="/tools/career-drift">Career Drift</a>
            <a href="/tools/ai-probability">AI Probability</a>
            <a href="/tools/group-project">Group Project</a>
            <a href="/tools/relationship-roi">Relationship ROI</a>
            <a href="/tools/existential-alarm">Existential Alarm</a>
          </div>
          <div class="footer-col">
            <h4>Company</h4>
            <a href="/about">About Us</a>
            <a href="/contact">Contact</a>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Service</a>
          </div>
        </div>
        <div class="footer-bottom">
          &copy; {new Date().getFullYear()} RealityCheck.tools &mdash; Get Roasted. Get Better.
        </div>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  (function() {
    var theme = localStorage.getItem('realitycheck-theme');
    if (!theme) { theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'; }
    if (theme === 'dark') { document.documentElement.setAttribute('data-theme', 'dark'); }

    document.addEventListener('DOMContentLoaded', function() {
      var toggle = document.getElementById('theme-toggle');
      if (toggle) {
        if (document.documentElement.getAttribute('data-theme') === 'dark') { toggle.textContent = '☀️'; }
        toggle.addEventListener('click', function() {
          var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          document.documentElement.setAttribute('data-theme', isDark ? '' : 'dark');
          localStorage.setItem('realitycheck-theme', isDark ? 'light' : 'dark');
          toggle.textContent = isDark ? '🌙' : '☀️';
        });
      }

      var hamburger = document.getElementById('hamburger');
      var topNav = document.getElementById('top-nav');
      if (hamburger && topNav) {
        hamburger.addEventListener('click', function() {
          hamburger.classList.toggle('active');
          topNav.classList.toggle('open');
          document.body.style.overflow = topNav.classList.contains('open') ? 'hidden' : '';
        });
        var navLinks = topNav.querySelectorAll('a');
        navLinks.forEach(function(link) {
          link.addEventListener('click', function() {
            hamburger.classList.remove('active');
            topNav.classList.remove('open');
            document.body.style.overflow = '';
          });
        });
      }
    });
  })();
</script>

<style is:global>
  *,
  *::before,
  *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --primary: #cc785c;
    --primary-active: #a9583e;
    --primary-disabled: #e6dfd8;
    --ink: #141413;
    --body: #3d3d3a;
    --body-strong: #252523;
    --muted: #6c6a64;
    --muted-soft: #8e8b82;
    --hairline: #e6dfd8;
    --hairline-soft: #ebe6df;
    --canvas: #faf9f5;
    --surface-soft: #f5f0e8;
    --surface-card: #efe9de;
    --surface-cream-strong: #e8e0d2;
    --surface-dark: #181715;
    --surface-dark-elevated: #252320;
    --surface-dark-soft: #1f1e1b;
    --on-primary: #ffffff;
    --on-dark: #faf9f5;
    --on-dark-soft: #a09d96;
    --accent-teal: #5db8a6;
    --accent-amber: #e8a55a;
    --success: #5db872;
    --warning: #d4a017;
    --error: #c64545;
    --display: 'EB Garamond', 'Tiempos Headline', 'Cormorant Garamond', Georgia, serif;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --radius-xs: 4px;
    --radius-sm: 6px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --radius-pill: 9999px;
    --space-xxs: 4px;
    --space-xs: 8px;
    --space-sm: 12px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 32px;
    --space-xxl: 48px;
    --space-section: 96px;
    --max-width: 1200px;
    --header-height: 64px;
  }

  [data-theme="dark"] {
    --primary: #d4856a;
    --primary-active: #e09175;
    --primary-disabled: #3d322e;
    --ink: #f0ece4;
    --body: #b5b0a8;
    --body-strong: #d0cbc3;
    --muted: #8e8a82;
    --muted-soft: #6e6a62;
    --hairline: #2d2b28;
    --hairline-soft: #252320;
    --canvas: #11100e;
    --surface-soft: #1a1916;
    --surface-card: #1f1e1b;
    --surface-cream-strong: #2d2b28;
    --surface-dark: #0a0a08;
    --surface-dark-elevated: #181715;
    --surface-dark-soft: #141310;
    --on-primary: #11100e;
    --on-dark: #f0ece4;
    --on-dark-soft: #8e8a82;
    --accent-teal: #4da892;
    --accent-amber: #c8913e;
    --success: #4da45e;
    --warning: #b88c0e;
    --error: #b53a3a;
  }

  html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

  body {
    font-family: var(--sans);
    background: var(--canvas);
    color: var(--ink);
    line-height: 1.6;
    min-height: 100vh;
    transition: background 0.3s, color 0.3s;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  h1, h2, h3 {
    font-family: var(--display);
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  h1 { font-size: 48px; line-height: 1.1; }
  h2 { font-size: 36px; line-height: 1.15; }
  h3 { font-size: 28px; line-height: 1.2; letter-spacing: -0.3px; }
  h4 { font-size: 22px; line-height: 1.3; font-family: var(--sans); font-weight: 500; letter-spacing: 0; }
  h5 { font-size: 18px; line-height: 1.4; font-family: var(--sans); font-weight: 500; }

  .site-header {
    height: var(--header-height);
    background: var(--canvas);
    border-bottom: 1px solid var(--hairline);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.3s;
  }

  .header-inner {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo {
    font-family: var(--display);
    font-size: 22px;
    font-weight: 400;
    color: var(--ink);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0;
    letter-spacing: -0.3px;
  }

  .logo-accent { color: var(--primary); }

  .logo-tld {
    color: var(--muted-soft);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    margin-left: 2px;
  }

  .theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--hairline);
    background: var(--surface-soft);
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    line-height: 1;
    padding: 0;
  }

  .theme-toggle:hover { border-color: var(--muted); }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 4px;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    border: 1px solid var(--hairline);
    background: var(--surface-soft);
    cursor: pointer;
    padding: 8px 6px;
    transition: all 0.2s;
  }

  .hamburger:hover { border-color: var(--muted); }

  .hamburger span {
    display: block;
    height: 2px;
    background: var(--body);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  .top-nav { display: flex; gap: 24px; align-items: center; }

  .top-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .top-nav a:hover { color: var(--ink); }

  main { min-height: calc(100vh - var(--header-height)); }

  .site-footer {
    background: var(--surface-dark);
    color: var(--on-dark-soft);
    padding: 64px 0;
    margin-top: 96px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .footer-col h4 {
    color: var(--on-dark);
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: var(--space-sm);
    letter-spacing: 0;
  }

  .footer-col a {
    display: block;
    color: var(--on-dark-soft);
    text-decoration: none;
    padding: 4px 0;
    font-size: 14px;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--on-dark); }

  .footer-bottom {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--surface-dark-elevated);
    text-align: center;
    font-size: 13px;
  }

  .hero-band {
    padding: var(--space-section) 0;
    text-align: center;
    position: relative;
  }

  .hero-band::after {
    content: '';
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(204, 120, 92, 0.06) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-band h1 {
    font-size: 64px;
    line-height: 1.05;
    letter-spacing: -1.5px;
    max-width: 800px;
    margin: 0 auto 16px;
    position: relative;
  }

  .hero-accent { color: var(--primary); }

  .hero-subtitle {
    font-size: 16px;
    color: var(--muted);
    max-width: 550px;
    margin: 0 auto var(--space-xl);
    line-height: 1.55;
    position: relative;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 64px;
    margin-top: var(--space-xxl);
    position: relative;
  }

  .stat { text-align: center; }

  .stat-value {
    display: block;
    font-family: var(--display);
    font-size: 36px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.5px;
  }

  .stat-label {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
    margin-top: 4px;
    display: block;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--primary);
    color: var(--on-primary);
    font-size: 14px;
    font-weight: 500;
    font-family: var(--sans);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.15s;
  }

  .btn-primary:hover { background: var(--primary-active); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--canvas);
    color: var(--ink);
    font-size: 14px;
    font-weight: 500;
    font-family: var(--sans);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--hairline);
    transition: border-color 0.2s;
  }

  .btn-secondary:hover { border-color: var(--muted); }

  .text-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: 500;
  }

  .text-link:hover { text-decoration: underline; }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .section-header h2 {
    font-size: 36px;
    letter-spacing: -0.5px;
    margin-bottom: 8px;
  }

  .section-subtitle {
    color: var(--muted);
    font-size: 16px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .tool-card {
    background: var(--surface-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-decoration: none;
    color: var(--ink);
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    border: 1px solid transparent;
  }

  .tool-card:hover {
    border-color: var(--primary);
    background: var(--surface-cream-strong);
  }

  .tool-card .pain {
    font-size: 12px;
    margin-bottom: var(--space-xs);
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .tool-card h3 {
    font-size: 22px;
    margin-bottom: var(--space-xs);
    letter-spacing: -0.3px;
  }

  .tool-card p {
    color: var(--body);
    font-size: 14px;
    line-height: 1.55;
    flex: 1;
  }

  .tool-card .card-footer {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--hairline-soft);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .category-tag {
    font-size: 12px;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    background: var(--canvas);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
  }

  .band-dark {
    background: var(--surface-dark);
    padding: var(--space-section) 0;
  }

  .band-dark h2 { color: var(--on-dark); }
  .band-dark .section-subtitle { color: var(--on-dark-soft); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .feature-card {
    background: var(--surface-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .feature-card-dark {
    background: var(--surface-dark-elevated);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .feature-card-dark .feature-emoji,
  .feature-card .feature-emoji {
    font-size: 2.5rem;
    margin-bottom: var(--space-md);
  }

  .feature-card-dark h5 {
    color: var(--on-dark);
    margin-bottom: var(--space-xs);
  }

  .feature-card-dark p {
    color: var(--on-dark-soft);
    font-size: 14px;
    line-height: 1.55;
  }

  .tool-hero {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 48px;
    padding-top: 48px;
  }

  .tool-hero h1 {
    font-size: 48px;
    letter-spacing: -1px;
  }

  .tool-hero .subtitle {
    color: var(--muted);
    font-size: 16px;
    margin-top: 12px;
  }

  .tool-form { max-width: 560px; margin: 0 auto; }

  .tool-input-group { margin-bottom: 20px; }

  .tool-input-group label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--body);
  }

  input[type="number"],
  input[type="text"],
  select,
  textarea {
    width: 100%;
    padding: 10px 14px;
    height: 40px;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    color: var(--ink);
    font-size: 16px;
    font-family: var(--sans);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  textarea { height: auto; }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(204, 120, 92, 0.15);
  }

  .checkbox-group { display: grid; gap: 10px; margin-bottom: 20px; }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface-soft);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .checkbox-item:hover { border-color: var(--muted); }

  .checkbox-item input[type="checkbox"] {
    accent-color: var(--primary);
    width: 18px;
    height: 18px;
  }

  .checkbox-item label {
    margin-bottom: 0;
    flex: 1;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
  }

  .checkbox-item .price {
    color: var(--muted);
    font-size: 13px;
  }

  .tone-selector {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
    justify-content: center;
  }

  .tone-btn {
    padding: 8px 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--sans);
    transition: all 0.2s;
  }

  .tone-btn:hover { color: var(--ink); border-color: var(--muted); }

  .tone-btn.active {
    background: var(--surface-card);
    color: var(--ink);
    border-color: var(--surface-cream-strong);
  }

  .result-card {
    background: var(--surface-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .result-text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--body);
  }

  .result-text strong { color: var(--ink); font-weight: 600; }

  .result-text .highlight-green { color: var(--success); }
  .result-text .highlight-yellow { color: var(--accent-amber); }

  .share-section {
    margin-top: var(--space-lg);
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .share-btn {
    padding: 10px 20px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--hairline);
    background: var(--canvas);
    color: var(--ink);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    font-family: var(--sans);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: border-color 0.2s;
  }

  .share-btn:hover { border-color: var(--muted); }

  .share-card-wrapper { margin-top: 20px; }

  .share-card {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1.91 / 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-dark);
    border: 1px solid var(--surface-dark-elevated);
  }

  .share-card::before {
    content: '';
